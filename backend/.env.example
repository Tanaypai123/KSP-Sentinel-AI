# KSP Sentinel AI - Environment Variables Example
PROJECT_NAME="KSP Sentinel AI"
API_V1_STR="/api/v1"
DEBUG=true

# Server Configuration
HOST=127.0.0.1
PORT=8000

# Database Configuration
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ksp_sentinel
POSTGRES_PORT=5432

# Database URL configuration (SQLAlchemy)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ksp_sentinel

# CORS Configuration (comma-separated list of allowed origins)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
